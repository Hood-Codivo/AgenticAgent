# Copy this file to ~/.hermes/.env and replace placeholder values.
# Keep real keys out of the project directory.

# LLM provider credentials. Pick at least one if you want Hermes/Groq/OpenRouter LLM calls.
export OPENROUTER_API_KEY="your-openrouter-key"
export GROQ_API_KEY="your-groq-key"
export GROQ_MODEL="llama-3.3-70b-versatile"

# Market data provider.
# Free/no-key options: yfinance, deriv
# Paid/keyed options: oanda, twelvedata
# Offline fallback: csv
export HERMES_DATA_PROVIDER="yfinance"
export HERMES_SYMBOL="EURUSD"
export HERMES_WATCHLIST="EURUSD,GBPUSD,AAPL,BTCUSD"
export HERMES_INTERVAL="1h"

# High-impact news risk filter.
# Uses ForexFactory's weekly JSON export by default.
export NEWS_BLOCK_BEFORE_MINUTES="60"
export NEWS_BLOCK_AFTER_MINUTES="30"
export NEWS_CACHE_SECONDS="900"

# Deriv public market data. Required only if you register your own Deriv app.
# The code defaults to Deriv's public app_id 1089 when this is unset.
export DERIV_APP_ID=""

# OANDA forex data. Required only when HERMES_DATA_PROVIDER=oanda.
export OANDA_API_KEY="your-oanda-api-token"
export OANDA_ENV="practice"

# Twelve Data market data. Required only when HERMES_DATA_PROVIDER=twelvedata.
export TWELVE_DATA_API_KEY="your-twelve-data-api-key"

# Optional Telegram alerts.
export TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# Comma-separated numeric Telegram user IDs allowed to use telegram_bot.py.
export TELEGRAM_ALLOWED_USERS="123456789"
# Optional destination override for automatic trade alerts. If unset, TELEGRAM_ALLOWED_USERS is used.
export TELEGRAM_ALERT_CHAT_IDS="123456789"
# Automatic strong-setup monitor: checks the watchlist every 15 minutes.
export HERMES_ALERT_MONITOR="false"
export HERMES_ALERT_POLL_SECONDS="900"
export HERMES_ALERT_QUALITY_MIN="90"
export HERMES_ALERT_REPEAT_SECONDS="21600"
